# ═══════════════════════════════════════════════════════════════════════════
#  Minecraft AI Manager — Environment Configuration
#  Copy this file to .env and fill in every value marked CHANGE_ME.
#  Run `make setup` to have the wizard generate this file automatically.
# ═══════════════════════════════════════════════════════════════════════════

# ── Server ──────────────────────────────────────────────────────────────────
# Public port the web panel listens on (80 for HTTP, 443 if you add TLS)
HTTP_PORT=80

# ── Database ────────────────────────────────────────────────────────────────
POSTGRES_DB=craftcontrol
POSTGRES_USER=craftcontrol
POSTGRES_PASSWORD=CHANGE_ME          # min 20 random chars

# ── Redis ───────────────────────────────────────────────────────────────────
REDIS_PASSWORD=CHANGE_ME             # min 20 random chars

# ── JWT (auth tokens) ───────────────────────────────────────────────────────
JWT_SECRET=CHANGE_ME                 # 64 random hex chars
JWT_REFRESH_SECRET=CHANGE_ME         # 64 random hex chars (different from above)
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ── Plugin bridge ───────────────────────────────────────────────────────────
# Shared secret between the web API and the Minecraft BridgePlugin.
# Automatically injected into the bundled Minecraft container as CFG_BRIDGE_SECRET.
BRIDGE_SECRET=CHANGE_ME              # 32 random hex chars

# ── Minecraft server ────────────────────────────────────────────────────────
# The Minecraft server runs as part of the Docker Compose stack.
MINECRAFT_VERSION=26.1.2
MINECRAFT_MEMORY=4G

# ── Minecraft RCON ──────────────────────────────────────────────────────────
# Enables server console commands from the web panel and MCP server.
# This password is automatically applied to the bundled Minecraft container.
RCON_PORT=25575
RCON_PASSWORD=CHANGE_ME              # 32 random hex chars

# ── Admin account ────────────────────────────────────────────────────────────
# First SUPER_ADMIN account created on startup.
# Also used by the MCP server to authenticate with the API.
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=CHANGE_ME             # min 12 chars

# ── MCP server (Claude AI tool access) ──────────────────────────────────────
# The MCP server lets Claude control your server via 52 tools.
# After deploy, add to Claude Desktop / Claude Code config:
#
#   {
#     "mcpServers": {
#       "craftcontrol": {
#         "transport": "sse",
#         "url": "http://YOUR_SERVER_IP:3100/sse",
#         "headers": { "Authorization": "Bearer <MCP_AUTH_TOKEN>" }
#       }
#     }
#   }
MCP_PORT=3100
MCP_AUTH_TOKEN=CHANGE_ME             # any random secret; leave blank to disable auth

# ── Docker image tag (set automatically by deploy.sh) ────────────────────────
IMAGE_TAG=latest
