# ═══════════════════════════════════════════════════════════════════════════
#  Minecraft AI Manager — Environment Configuration
#  Copy this file to .env and fill in every value marked CHANGE_ME.
#  Run `make setup` to have the wizard generate this file automatically.
# ═══════════════════════════════════════════════════════════════════════════

# ── Server ──────────────────────────────────────────────────────────────────
# Public port the web panel listens on (80 for HTTP, 443 if you add TLS)
HTTP_PORT=80

# ── Database ────────────────────────────────────────────────────────────────
POSTGRES_DB=craftcontrol
POSTGRES_USER=craftcontrol
POSTGRES_PASSWORD=CHANGE_ME          # min 20 random chars

# ── Redis ───────────────────────────────────────────────────────────────────
REDIS_PASSWORD=CHANGE_ME             # min 20 random chars

# ── JWT (auth tokens) ───────────────────────────────────────────────────────
JWT_SECRET=CHANGE_ME                 # 64 random hex chars
JWT_REFRESH_SECRET=CHANGE_ME         # 64 random hex chars (different from above)
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ── Plugin bridge ───────────────────────────────────────────────────────────
# Shared secret between the web API and the Minecraft BridgePlugin.
# Copy this value into DiscoPanel → Environment Variables as BRIDGE_SECRET.
BRIDGE_SECRET=CHANGE_ME              # 32 random hex chars

# ── Game server connection ───────────────────────────────────────────────────
# IP or hostname of the machine running the Minecraft server.
# Use 10.10.10.10 if following the DEPLOYMENT.md two-VM topology.
GAME_VM_HOST=10.10.10.10

# ── Docker image tag (set automatically by deploy.sh) ────────────────────────
IMAGE_TAG=latest
