# ═══════════════════════════════════════════════════════════════════
#  Minecraft AI Manager — default configuration
#
#  ⚠  CHANGE ALL SECRETS BELOW BEFORE EXPOSING TO THE INTERNET  ⚠
#  Generate a new secret: openssl rand -hex 32
#  After changing, restart: docker compose up -d
# ═══════════════════════════════════════════════════════════════════

# Web panel port (change to 8080 if port 80 is taken)
HTTP_PORT=80

# ── Database ────────────────────────────────────────────────────────
POSTGRES_DB=craftcontrol
POSTGRES_USER=craftcontrol
POSTGRES_PASSWORD=02c7243260d34ca6b441fe638869d1821f3ab597   # ⚠ change me

# ── Redis ───────────────────────────────────────────────────────────
REDIS_PASSWORD=96c9fa2c3104a5d8a3c7e4b1e35170668198b69f       # ⚠ change me

# ── JWT ─────────────────────────────────────────────────────────────
JWT_SECRET=fa8e6907f118da372dba47a081060c5c855c5a09c87563d0e329a8d0a593191f           # ⚠ change me
JWT_REFRESH_SECRET=7c089ad8e92000b545ef3d225133e50debac35ecae217185093bd05c59e1eab3   # ⚠ change me
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ── Minecraft bridge ────────────────────────────────────────────────
BRIDGE_SECRET=27e105d687cf1bf159b78245eb90e1f6   # ⚠ change me

# ── Minecraft server ────────────────────────────────────────────────
MINECRAFT_MEMORY=4G          # RAM for the Minecraft JVM (needs 4G free on host)
RCON_PORT=25575
RCON_PASSWORD=changeme_rcon  # ⚠ change me (internal only, not exposed publicly)

# ── First-run admin account ─────────────────────────────────────────
# Created automatically on first startup. Change password after first login.
# After logging in, remove ADMIN_EMAIL and ADMIN_PASSWORD from this file
# and run: docker compose up -d
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=changeme123   # ⚠ change immediately after first login
