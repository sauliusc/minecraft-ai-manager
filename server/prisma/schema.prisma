generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Player {
  username       String              @id
  firstJoinAt    DateTime
  lastSeenAt     DateTime
  joinCount      Int                 @default(0)
  currentStreak  Int                 @default(0)
  longestStreak  Int                 @default(0)
  lastLoginDate  DateTime?
  coins          Int                 @default(0)
  crystals       Int                 @default(0)
  safechat       Boolean             @default(false)
  rewards        PlayerReward[]
  progress       ChallengeProgress[]
  listings       MarketListing[]     @relation("SellerListings")
  purchases      MarketListing[]     @relation("BuyerListings")
}

model Challenge {
  id             String              @id @default(cuid())
  title          String
  description    String
  type           ChallengeType
  difficulty     Int                 @default(1)
  config         Json
  rewardId       String?
  reward         Reward?             @relation(fields: [rewardId], references: [id])
  activeFrom     DateTime
  activeUntil    DateTime
  assignedTo     String[]
  questCategory  QuestCategory?
  progress       ChallengeProgress[]

  @@index([questCategory])
}

model ChallengeProgress {
  id          String    @id @default(cuid())
  playerId    String
  challengeId String
  current     Int       @default(0)
  completed   Boolean   @default(false)
  completedAt DateTime?
  player      Player    @relation(fields: [playerId], references: [username], onDelete: Cascade)
  challenge   Challenge @relation(fields: [challengeId], references: [id], onDelete: Cascade)

  @@unique([playerId, challengeId])
  @@index([playerId])
  @@index([challengeId])
}

model Reward {
  id         String         @id @default(cuid())
  name       String
  type       RewardType
  rarity     RewardRarity   @default(COMMON)
  config     Json
  lootTable  Json?
  challenges Challenge[]
  grants     PlayerReward[]
}

model PlayerReward {
  id        String   @id @default(cuid())
  playerId  String
  rewardId  String
  grantedAt DateTime @default(now())
  grantedBy String
  player    Player   @relation(fields: [playerId], references: [username], onDelete: Cascade)
  reward    Reward   @relation(fields: [rewardId], references: [id], onDelete: Restrict)

  @@index([playerId])
}

model User {
  id             String          @id @default(cuid())
  email          String          @unique
  name           String          @default("")
  passwordHash   String
  role           Role            @default(MODERATOR)
  autoConfirm    Boolean         @default(false)
  isActive       Boolean         @default(true)
  lastLoginAt    DateTime?
  createdBy      String?
  createdAt      DateTime        @default(now())

  activityLogs   ActivityLog[]
  pendingActions PendingAction[] @relation("PendingActionUser")
  reviews        PendingAction[] @relation("PendingActionReviewer")
}

enum ActivityStatus {
  SUCCESS
  PENDING
  CONFIRMED
  REJECTED
  FAILED
}

enum PendingStatus {
  PENDING
  CONFIRMED
  REJECTED
}

model ActivityLog {
  id              String         @id @default(cuid())
  userId          String
  userEmail       String
  action          String
  resource        String
  resourceId      String?
  method          String
  path            String
  requestBody     Json?
  ipAddress       String
  status          ActivityStatus @default(SUCCESS)
  pendingActionId String?
  createdAt       DateTime       @default(now())

  user            User           @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([resource])
  @@index([status])
  @@index([createdAt])
}

model PendingAction {
  id           String        @id @default(cuid())
  userId       String
  userEmail    String
  action       String
  resource     String
  method       String
  path         String
  body         Json
  status       PendingStatus @default(PENDING)
  reviewedBy   String?
  reviewedAt   DateTime?
  executedAt   DateTime?
  result       Json?
  createdAt    DateTime      @default(now())

  user         User          @relation("PendingActionUser",    fields: [userId],     references: [id])
  reviewer     User?         @relation("PendingActionReviewer", fields: [reviewedBy], references: [id])

  @@index([userId])
  @@index([status])
  @@index([createdAt])
}

enum ChallengeType {
  BLOCK_BREAK
  KILL_MOB
  CRAFT_ITEM
  TRAVEL
  CUSTOM
}

enum QuestCategory {
  DAILY
  WEEKLY
  SIDE
}

enum RewardType {
  ITEM
  XP
  COMMAND
  CURRENCY
  MYSTERY_BOX
}

enum RewardRarity {
  COMMON
  RARE
  EPIC
  LEGENDARY
}

enum Role {
  SUPER_ADMIN
  MODERATOR
}

model GameEvent {
  id               String          @id @default(cuid())
  type             GameEventType
  title            String
  state            GameEventState  @default(UPCOMING)
  scheduledAt      DateTime
  endedAt          DateTime?
  config           Json            @default("{}")
  participantCount Int             @default(0)
  createdAt        DateTime        @default(now())
  leaderboard      EventLeaderboardEntry[]
}

model EventLeaderboardEntry {
  id         String    @id @default(cuid())
  eventId    String
  playerId   String
  playerName String
  score      Float     @default(0)
  event      GameEvent @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@unique([eventId, playerId])
}

enum GameEventType {
  BOSS_RAID
  TREASURE_HUNT
  BUILD_BATTLE
  CLAN_WAR
}

enum GameEventState {
  UPCOMING
  ACTIVE
  FINISHED
}

model ModerationReport {
  id           String         @id @default(cuid())
  reporterId   String
  reportedId   String
  reason       String
  chatSnapshot String[]
  status       ReportStatus   @default(PENDING)
  escalated    Boolean        @default(false)
  resolvedAt   DateTime?
  resolvedBy   String?
  createdAt    DateTime       @default(now())

  @@index([status])
  @@index([reportedId])
  @@index([createdAt])
}

model ModerationAction {
  id         String         @id @default(cuid())
  targetId   String
  adminId    String
  type       ActionType
  reason     String
  expiresAt  DateTime?
  createdAt  DateTime       @default(now())
}

model PlayerBlock {
  id        String   @id @default(cuid())
  blockerId String
  blockedId String
  createdAt DateTime @default(now())

  @@unique([blockerId, blockedId])
}

model ChatLog {
  id        String   @id @default(cuid())
  playerId  String
  username  String
  message   String
  flagged   Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([playerId])
  @@index([createdAt])
  @@index([flagged])
}

model BroadcastMessage {
  id          String          @id @default(cuid())
  content     String
  channels    String[]
  audience    String          @default("ALL")
  scheduledAt DateTime?
  sentAt      DateTime?
  status      BroadcastStatus @default(DRAFT)
  createdBy   String
  createdAt   DateTime        @default(now())

  @@index([status])
  @@index([scheduledAt])
}

enum ReportStatus {
  PENDING
  REVIEWED
  ESCALATED
  RESOLVED
}

enum ActionType {
  MUTE
  UNMUTE
  KICK
  BAN
  UNBAN
}

enum BroadcastStatus {
  DRAFT
  SCHEDULED
  SENT
  CANCELLED
}

model NpcDefinition {
  id            String              @id @default(cuid())
  name          String
  skinUrl       String              @default("")
  title         String              @default("")
  locWorld      String              @default("world")
  locX          Float               @default(0)
  locY          Float               @default(64)
  locZ          Float               @default(0)
  locYaw        Float               @default(0)
  type          NpcType             @default(GUIDE)
  dialogueLines String[]
  questIds      String[]
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt
  relationships PlayerNpcRelationship[]
}

model PlayerNpcRelationship {
  id                String   @id @default(cuid())
  playerId          String
  npcId             String
  relationshipScore Int      @default(0)
  completedQuestIds String[]
  updatedAt         DateTime @updatedAt
  npc               NpcDefinition @relation(fields: [npcId], references: [id], onDelete: Cascade)

  @@unique([playerId, npcId])
}

enum NpcType {
  GUIDE
  QUEST_GIVER
  MERCHANT
}

model MarketListing {
  id        String    @id @default(cuid())
  sellerId  String
  buyerId   String?
  material  String
  amount    Int
  price     Int
  fee       Int       @default(0)
  sold      Boolean   @default(false)
  expiresAt DateTime
  soldAt    DateTime?
  createdAt DateTime  @default(now())
  seller    Player    @relation("SellerListings", fields: [sellerId], references: [username], onDelete: Cascade)
  buyer     Player?   @relation("BuyerListings", fields: [buyerId], references: [username])

  @@index([sellerId])
  @@index([sold])
  @@index([expiresAt])
}

model EconomyAuditLog {
  id        String   @id @default(cuid())
  adminId   String
  targetId  String
  delta     Int
  currency  String
  reason    String
  createdAt DateTime @default(now())

  @@index([targetId])
  @@index([createdAt])
}

model Clan {
  id        String       @id @default(cuid())
  name      String       @unique
  tag       String       @unique
  leaderId  String
  xp        Int          @default(0)
  level     Int          @default(1)
  homeWorld String?
  homeX     Float?
  homeY     Float?
  homeZ     Float?
  createdAt DateTime     @default(now())
  members   ClanMember[]
  invites   ClanInvite[]

  @@index([leaderId])
}

model ClanMember {
  id       String   @id @default(cuid())
  clanId   String
  playerId String
  role     ClanRole @default(MEMBER)
  joinedAt DateTime @default(now())
  clan     Clan     @relation(fields: [clanId], references: [id], onDelete: Cascade)

  @@unique([playerId])
  @@index([clanId])
}

model ClanInvite {
  id         String   @id @default(cuid())
  clanId     String
  inviterId  String
  inviteeId  String
  createdAt  DateTime @default(now())
  expiresAt  DateTime
  clan       Clan     @relation(fields: [clanId], references: [id], onDelete: Cascade)

  @@unique([clanId, inviteeId])
  @@index([inviteeId])
}

model ClanWar {
  id         String       @id
  clan1Id    String
  clan2Id    String
  type       String
  durationMs Int
  winnerId   String?
  clan1Score Int          @default(0)
  clan2Score Int          @default(0)
  startedAt  DateTime     @default(now())
  endedAt    DateTime?

  @@index([clan1Id])
  @@index([clan2Id])
}

enum ClanRole {
  LEADER
  OFFICER
  MEMBER
}

model PlayerCosmetics {
  playerId     String   @id
  titleId      String?
  chatColor    String?
  particleType String?
  petType      String?
  trailType    String?
  updatedAt    DateTime @updatedAt
}

model CosmeticTitle {
  id          String @id @default(cuid())
  name        String @unique
  description String @default("")
  createdAt   DateTime @default(now())
}

model PendingVote {
  id        String    @id @default(cuid())
  playerId  String
  site      String
  playerIgN String
  claimed   Boolean   @default(false)
  claimedAt DateTime?
  createdAt DateTime  @default(now())

  @@index([playerId])
  @@index([claimed])
}

model BroadcastTrigger {
  id        String              @id @default(cuid())
  type      BroadcastTriggerType
  enabled   Boolean             @default(true)
  config    Json                @default("{}")
  updatedAt DateTime            @updatedAt
  updatedBy String              @default("system")

  @@unique([type])
}

enum BroadcastTriggerType {
  DAILY_LOGIN
  MILESTONE
  LOW_ACTIVITY
}

// ── AI features ───────────────────────────────────────────────────────────────

model AiConfig {
  key       String   @id
  value     String
  updatedAt DateTime @default(now()) @updatedAt

  @@map("ai_config")
}

model AiChallengeDraft {
  id         String          @id @default(cuid())
  payload    Json
  confidence Float
  reasoning  String
  status     AiDraftStatus   @default(PENDING)
  reviewedBy String?
  createdAt  DateTime        @default(now())
  updatedAt  DateTime        @updatedAt

  @@index([status])
  @@map("ai_challenge_drafts")
}

model AiEngagementScan {
  id        String   @id @default(cuid())
  results   Json
  scannedAt DateTime @default(now())

  @@map("ai_engagement_scans")
}

model AiChatScan {
  id        String   @id @default(cuid())
  results   Json
  scannedAt DateTime @default(now())

  @@map("ai_chat_scans")
}

enum AiDraftStatus {
  PENDING
  APPROVED
  REJECTED
}

enum WeekThemeStatus {
  DRAFT
  ACTIVE
  EXPIRED
  CANCELLED
}

// ── Deployment / update history ───────────────────────────────────────────────

model Deployment {
  id          String   @id @default(cuid())
  imageTag    String                        // short git SHA or "manual"
  triggeredBy String                        // GitHub actor or admin email
  action      String                        // "deploy" | "restart" | "start" | "stop"
  notes       String?                       // commit message or manual note
  createdAt   DateTime @default(now())

  @@index([createdAt])
}

model WeekTheme {
  id               String          @id @default(cuid())
  theme            String
  description      String
  startDate        DateTime
  endDate          DateTime
  status           WeekThemeStatus @default(DRAFT)
  aiPayload        Json
  eventId          String?
  npcId            String?
  challengeIds     String[]
  rewardIds        String[]
  announcementText String?
  createdBy        String
  createdAt        DateTime        @default(now())
  activatedAt      DateTime?
  activatedBy      String?

  @@map("week_themes")
}
