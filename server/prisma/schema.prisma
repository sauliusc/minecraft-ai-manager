generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Player {
  id          String              @id
  username    String
  firstJoinAt DateTime
  lastSeenAt  DateTime
  joinCount   Int                 @default(0)
  rewards     PlayerReward[]
  progress    ChallengeProgress[]
}

model Challenge {
  id          String              @id @default(cuid())
  title       String
  description String
  type        ChallengeType
  config      Json
  rewardId    String?
  reward      Reward?             @relation(fields: [rewardId], references: [id])
  activeFrom  DateTime
  activeUntil DateTime
  assignedTo  String[]
  progress    ChallengeProgress[]
}

model ChallengeProgress {
  id          String    @id @default(cuid())
  playerId    String
  challengeId String
  current     Int       @default(0)
  completed   Boolean   @default(false)
  completedAt DateTime?
  player      Player    @relation(fields: [playerId], references: [id])
  challenge   Challenge @relation(fields: [challengeId], references: [id])

  @@unique([playerId, challengeId])
}

model Reward {
  id         String         @id @default(cuid())
  name       String
  type       RewardType
  config     Json
  challenges Challenge[]
  grants     PlayerReward[]
}

model PlayerReward {
  id        String   @id @default(cuid())
  playerId  String
  rewardId  String
  grantedAt DateTime @default(now())
  grantedBy String
  player    Player   @relation(fields: [playerId], references: [id])
  reward    Reward   @relation(fields: [rewardId], references: [id])
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  role         Role     @default(MODERATOR)
  createdAt    DateTime @default(now())
}

enum ChallengeType {
  BLOCK_BREAK
  KILL_MOB
  CRAFT_ITEM
  TRAVEL
  CUSTOM
}

enum RewardType {
  ITEM
  XP
  COMMAND
  CURRENCY
}

enum Role {
  SUPER_ADMIN
  MODERATOR
}

model GameEvent {
  id               String          @id @default(cuid())
  type             GameEventType
  title            String
  state            GameEventState  @default(UPCOMING)
  scheduledAt      DateTime
  endedAt          DateTime?
  config           Json            @default("{}")
  participantCount Int             @default(0)
  createdAt        DateTime        @default(now())
  leaderboard      EventLeaderboardEntry[]
}

model EventLeaderboardEntry {
  id         String    @id @default(cuid())
  eventId    String
  playerId   String
  playerName String
  score      Float     @default(0)
  event      GameEvent @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@unique([eventId, playerId])
}

enum GameEventType {
  BOSS_RAID
  TREASURE_HUNT
  BUILD_BATTLE
  CLAN_WAR
}

enum GameEventState {
  UPCOMING
  ACTIVE
  FINISHED
}

model ModerationReport {
  id           String         @id @default(cuid())
  reporterId   String
  reportedId   String
  reason       String
  chatSnapshot String[]
  status       ReportStatus   @default(PENDING)
  escalated    Boolean        @default(false)
  resolvedAt   DateTime?
  resolvedBy   String?
  createdAt    DateTime       @default(now())
}

model ModerationAction {
  id         String         @id @default(cuid())
  targetId   String
  adminId    String
  type       ActionType
  reason     String
  expiresAt  DateTime?
  createdAt  DateTime       @default(now())
}

model PlayerBlock {
  id        String   @id @default(cuid())
  blockerId String
  blockedId String
  createdAt DateTime @default(now())

  @@unique([blockerId, blockedId])
}

model ChatLog {
  id        String   @id @default(cuid())
  playerId  String
  username  String
  message   String
  flagged   Boolean  @default(false)
  createdAt DateTime @default(now())
}

model BroadcastMessage {
  id          String          @id @default(cuid())
  content     String
  channels    String[]
  audience    String          @default("ALL")
  scheduledAt DateTime?
  sentAt      DateTime?
  status      BroadcastStatus @default(DRAFT)
  createdBy   String
  createdAt   DateTime        @default(now())
}

enum ReportStatus {
  PENDING
  REVIEWED
  ESCALATED
  RESOLVED
}

enum ActionType {
  MUTE
  UNMUTE
  KICK
  BAN
  UNBAN
}

enum BroadcastStatus {
  DRAFT
  SCHEDULED
  SENT
  CANCELLED
}
